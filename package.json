{
  "name": "yingguangjiyou",
  "version": "0.0.2",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "keywords": [
    "game",
    "casual",
    "萤光纪游"
  ],
  "author": "",
  "license": "ISC",
  "description": "萤光纪游 - 一款有趣的休闲游戏",
  "repository": {
    "type": "git",
    "url": "https://github.com/BAIheZR/firefly.git"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.example.yingguangjiyou",
    "productName": "萤光纪游",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "main.js",
      "index.js",
      "preload.js",
      "index/**/*",
      "main/**/*",
      "img/**/*",
      "resource/**/*",
      "video/**/*"
    ],
    "extraResources": [
      {
        "from": "img/",
        "to": "img/"
      },
      {
        "from": "video/",
        "to": "video/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "萤光纪游",
      "installerHeaderIcon": "favicon.ico"
    }
  },
  "dependencies": {
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^8.3.4"
  }
}
